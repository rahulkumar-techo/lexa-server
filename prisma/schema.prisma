generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  name            String?
  passwordHash    String?          @map("password_hash")
  avatarUrl       String?          @map("avatar_url")
  bio             String?
  provider        String?
  providerId      String?          @map("provider_id")
  status          UserStatus       @default(INACTIVE)
  role            Role             @default(USER)
  isVerified      Boolean          @default(false) @map("is_verified")
  emailVerifiedAt DateTime?        @map("email_verified_at")

  sessions        Session[]
  preference      Preference?
  chats           Chat[]
  messages        Message[]
  files           File[]
  analytics       AnalyticsEvent[]
  subscriptions   Subscription[]

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([provider, providerId])
  @@map("users")
}

model Preference {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @db.Uuid @map("user_id")
  theme                String?  @default("system")
  language             String?  @default("en")
  learningLanguage     String?  @default("English") @map("learning_language")
  nativeLanguage       String?  @default("English") @map("native_language")
  learningLevel        String?  @default("beginner") @map("learning_level")
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("preferences")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model Chat {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid @map("user_id")
  title     String
  status    UserStatus @default(INACTIVE)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  context   Context?

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([userId])
  @@map("chats")
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  chatId    String      @db.Uuid @map("chat_id")
  userId    String?     @db.Uuid @map("user_id")
  role      MessageRole
  content   String
  metadata  Json?

  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime    @default(now()) @map("created_at")

  @@index([chatId])
  @@index([userId])
  @@map("messages")
}

model Context {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @unique @db.Uuid @map("chat_id")
  data      Json

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contexts")
}

model Scenario {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  config      Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("scenarios")
}

model File {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  url       String
  type      String
  size      Int?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("files")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  event     String
  metadata  Json?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("analytics_events")
}

model Subscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  provider  String
  status    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("subscriptions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum Role {
  USER
  ADMIN
}
